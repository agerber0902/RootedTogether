{
  "expo": {
    "name": "RootedTogether: Affirmations",
    "slug": "rootedtogether-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "RootedTogether",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "64a3e283-5e00-4d33-9d78-63baef70e35f"
      },
      "router": {}
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.RootedTogether",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "We use notifications to send you affirmations.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#898973"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.company.rootedtogether",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-firebase/messaging",
      "expo-notifications",
      [
        "expo-asset",
        {
          "assets": [
            "./assets/images/logo.png"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "useModularHeaders": true,
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAnalytics",
              "RNFBAppCheck",
              "RNFBAppDistribution",
              "RNFBAuth",
              "RNFBCrashlytics",
              "RNFBDatabase",
              "RNFBFirestore",
              "RNFBFunctions",
              "RNFBInAppMessaging",
              "RNFBInstallations",
              "RNFBMessaging",
              "RNFBML",
              "RNFBPerf",
              "RNFBRemoteConfig",
              "RNFBStorage"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "agerber0902"
  }
}